---
interface Project {
  slug: string;
  title: string;
  description: string;
  image: string;
  tags: string[];
  liveUrl: string | null;
  githubUrl: string;
}

interface Props {
  project: Project;
  featured?: boolean;
}

const { project, featured = false } = Astro.props;

function tagColor(tag: string): string {
  if (tag.includes('React') || tag.includes('Next')) return 'bg-blue-500/10 text-blue-400';
  if (tag.includes('Type')) return 'bg-blue-400/10 text-blue-300';
  if (tag.includes('D3') || tag.includes('Data')) return 'bg-green-500/10 text-green-400';
  if (tag.includes('OpenAI') || tag.includes('AI')) return 'bg-purple-500/10 text-purple-400';
  if (tag.includes('Mobile') || tag.includes('Expo')) return 'bg-orange-500/10 text-orange-400';
  return 'bg-primary-500/10 text-primary-400';
}
---

<article class="group relative">
  <div class="relative overflow-hidden rounded-xl border border-white/5 bg-card/80 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-primary-500/10">
    <a href={`/projects/${project.slug}`} class="block">
      <div class="aspect-video relative overflow-hidden">
        <img
          src={project.image}
          alt={`Screenshot of ${project.title}`}
          width={640}
          height={360}
          loading={featured ? 'eager' : 'lazy'}
          decoding="async"
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
      </div>
    </a>
    <div class="p-6 space-y-4">
      <h3 class="text-xl font-semibold">
        <a href={`/projects/${project.slug}`} class="hover:text-primary-400 transition-colors">
          {project.title}
        </a>
      </h3>
      <p class="text-medium-contrast text-sm leading-relaxed">{project.description}</p>
      <ul class="flex flex-wrap gap-2" aria-label="Technologies used">
        {project.tags.map((tag) => (
          <li>
            <span class={`px-3 py-1 text-xs font-medium rounded-full ${tagColor(tag)}`}>{tag}</span>
          </li>
        ))}
      </ul>
      <div class="flex flex-wrap gap-3 pt-2">
        {project.liveUrl && (
          <a
            href={project.liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-outline text-sm py-2 px-4"
          >
            Live Demo
          </a>
        )}
        <a
          href={project.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-outline text-sm py-2 px-4"
        >
          View Code
        </a>
      </div>
    </div>
  </div>
</article>
