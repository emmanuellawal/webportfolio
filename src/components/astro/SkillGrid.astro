---
import skills from '@/data/skills.json';
import ScrollReveal from './ScrollReveal.astro';
import SectionHeading from './SectionHeading.astro';

const iconMap: Record<string, string> = {
  code: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  server: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2',
  palette: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
  brain: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
};

const borderColors = ['border-l-primary-500', 'border-l-secondary-500', 'border-l-accent-500', 'border-l-primary-400'];

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<section id="skills" class:list={['pb-16', className]} aria-labelledby="skills-heading">
  <ScrollReveal>
    <div class="text-center space-y-4 mb-12">
      <SectionHeading id="skills-heading">My Skills</SectionHeading>
      <p class="text-lg text-medium-contrast max-w-2xl mx-auto">
        Key areas where I excel and the technologies I work with.
      </p>
    </div>
  </ScrollReveal>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    {skills.map((skill, i) => (
      <ScrollReveal delay={i * 100}>
        <article class={`rounded-xl border border-white/5 border-l-4 ${borderColors[i % borderColors.length]} bg-card/40 backdrop-blur-sm p-6 hover-lift`}>
          <div class="flex items-center gap-2 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary-400" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconMap[skill.icon] ?? iconMap.code} />
            </svg>
            <h3 class="text-lg font-semibold">{skill.category}</h3>
          </div>
          <p class="text-sm text-muted-foreground mb-3">{skill.description}</p>
          <ul class="flex flex-wrap gap-2">
            {skill.skills.map((s) => (
              <li><span class="text-xs px-2 py-1 rounded bg-muted text-muted-foreground">{s}</span></li>
            ))}
          </ul>
        </article>
      </ScrollReveal>
    ))}
  </div>
</section>
