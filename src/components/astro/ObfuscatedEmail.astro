---
interface Props {
  variant?: 'link' | 'icon';
  class?: string;
}

const { variant = 'link', class: className = '' } = Astro.props;
---

{
  variant === 'link' ? (
    <a
      data-obfuscated-email
      class:list={['text-primary-400 hover:underline', className]}
      aria-label="Send me an email"
    >
      Email
    </a>
  ) : (
    <a
      data-obfuscated-email
      class:list={['hover:text-foreground transition-colors', className]}
      aria-label="Email"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <rect width="20" height="16" x="2" y="4" rx="2" />
        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
      </svg>
    </a>
  )
}
