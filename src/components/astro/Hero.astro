---
import profile from '@/data/profile.json';
import projects from '@/data/projects.json';
import ObfuscatedEmail from './ObfuscatedEmail.astro';

const { name, role, tagline, location, availability } = profile;

const heroProject =
  projects.find((p) => p.slug === 'three-decades-of-mobility') ?? projects[0];
const heroImage = heroProject.image;
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="site-shell hero__copy">
    <p class="hero__availability">{availability.label} · {location}</p>
    <h1 id="hero-heading" class="hero__name brand-underline">{name}</h1>
    <p class="hero__tagline">{role}. {tagline}</p>
    <p class="hero__sub">Interfaces and systems built to feel intentional — including where AI is involved.</p>
    <div class="hero__actions">
      <a href="/projects" class="btn-primary">View selected work</a>
      <ObfuscatedEmail class="btn-ghost" label="Email me" />
    </div>
  </div>

  <div class="hero__visual">
    <img
      src={heroImage}
      alt={`Screenshot of ${heroProject.title}`}
      width="2400"
      height="1000"
      fetchpriority="high"
      decoding="async"
      class="hero__image"
    />
  </div>
</section>

<style>
  .hero {
    min-height: min(100dvh, 56rem);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-top: 2rem;
  }

  .hero__copy {
    padding-block: clamp(2rem, 6vw, 4rem);
    max-width: 42rem;
  }

  .hero__availability {
    margin: 0 0 1.25rem;
    font-size: 0.875rem;
    color: var(--text-3);
    font-variant-numeric: tabular-nums;
  }

  .hero__name {
    margin: 0 0 0.75rem;
  }

  .hero__tagline {
    margin: 0 0 0.75rem;
    max-width: 40ch;
    color: var(--text);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 600;
    line-height: 1.35;
  }

  .hero__sub {
    margin: 0 0 2rem;
    max-width: 38ch;
    color: var(--text-2);
    font-size: 1.0625rem;
    line-height: 1.65;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero__visual {
    width: 100%;
    margin-top: auto;
  }

  .hero__image {
    display: block;
    width: 100%;
    height: clamp(14rem, 38vw, 28rem);
    object-fit: cover;
    object-position: top center;
    border-top: 1px solid var(--hairline);
  }
</style>
