---
import profile from '@/data/profile.json';
import ObfuscatedEmail from './ObfuscatedEmail.astro';

const year = new Date().getFullYear();
const { name, social } = profile;

const utilityLinks = [
  { href: '/resume.txt', label: 'Resume', download: 'Emmanuel-Lawal-Resume.txt' },
  { href: social.github, label: 'GitHub', external: true },
  { href: social.linkedin, label: 'LinkedIn', external: true },
  { href: '/privacy', label: 'Privacy' },
  { href: '/terms', label: 'Terms' },
];
---

<footer class="site-footer">
  <div class="site-shell site-footer__inner">
    <p class="site-footer__name">{name}</p>
    <nav class="site-footer__nav" aria-label="Footer">
      <ObfuscatedEmail class="site-footer__link" />
      {utilityLinks.map((link) => (
        <a
          href={link.href}
          class="site-footer__link"
          {...(link.download ? { download: link.download } : {})}
          {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <p class="site-footer__copy">© {year} {name}</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    padding-block: clamp(3rem, 6vw, 5rem);
    border-top: 1px solid var(--hairline);
  }

  .site-footer__inner {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .site-footer__name {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0;
    text-wrap: balance;
  }

  .site-footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    align-items: center;
  }

  .site-footer__link {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-2);
    text-decoration: none;
    min-height: 2.75rem;
    display: inline-flex;
    align-items: center;
  }

  .site-footer__link:hover {
    color: var(--accent-on-dark);
  }

  .site-footer__copy {
    margin: 0;
    font-size: 0.875rem;
    color: var(--text-3);
  }
</style>
