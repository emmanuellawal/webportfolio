---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  priority?: boolean;
  alt?: string;
  class?: string;
}

const {
  size = 'sm',
  priority = false,
  alt = 'Emmanuel Lawal',
  class: className = '',
} = Astro.props;

const sizeClasses = {
  sm: 'w-24 h-24',
  md: 'w-28 h-28',
  lg: 'w-48 h-48',
};

const pixelMap = { sm: 96, md: 112, lg: 192 } as const;
const pixelSize = pixelMap[size];
---

<div class:list={['relative mx-auto p-3', className]}>
  <div
    class="absolute inset-0 rounded-full bg-gradient-to-br from-primary-500 to-secondary-500 blur-lg opacity-50"
    aria-hidden="true"
  />
  <div
    class:list={[
      'relative mx-auto rounded-full overflow-hidden border-4 border-background',
      'ring-2 ring-primary-500/50 ring-offset-2 ring-offset-background',
      sizeClasses[size],
    ]}
  >
    <img
      src="/pic/1image.jpg"
      alt={alt}
      width={pixelSize}
      height={pixelSize}
      loading={priority ? 'eager' : 'lazy'}
      fetchpriority={priority ? 'high' : 'auto'}
      decoding="async"
      class="h-full w-full object-cover object-top"
    />
  </div>
</div>
