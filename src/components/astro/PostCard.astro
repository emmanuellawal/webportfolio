---
import { formatDate, slugify } from '@/lib/utils';

interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  tags: string[];
  readingTime: number;
}

const { title, description, slug, pubDate, tags, readingTime } = Astro.props;
---

<article class="writing-list__row post-card">
  <div>
    <h3 class="writing-list__title">
      <a href={`/blog/${slug}`} class="post-card__link">{title}</a>
    </h3>
    <p class="text-muted text-sm mt-2 mb-0">{description}</p>
    {tags.length > 0 && (
      <p class="text-subtle text-sm mt-3 mb-0">
        {tags.map((tag, i) => (
          <>
            {i > 0 && ', '}
            <a href={`/blog/tags/${slugify(tag)}`} class="text-link text-sm">{tag}</a>
          </>
        ))}
      </p>
    )}
  </div>
  <p class="writing-list__meta">
    <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
    {' · '}
    {readingTime} min
  </p>
</article>

<style>
  .post-card {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .post-card {
      flex-direction: row;
      align-items: baseline;
    }
  }

  .post-card__link {
    color: inherit;
    text-decoration: none;
  }

  .post-card__link:hover {
    color: var(--accent-on-dark);
  }
</style>
