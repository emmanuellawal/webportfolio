---
interface Props {
  as?: 'h1' | 'h2' | 'h3';
  id?: string;
  size?: string;
  align?: 'left' | 'center';
  class?: string;
}

const {
  as: Tag = 'h2',
  id,
  size = 'text-3xl',
  align = 'center',
  class: className = '',
} = Astro.props;
---

<div class:list={['section-heading', align === 'center' && 'mx-auto', className]}>
  <Tag id={id} class:list={[size, 'font-bold text-gradient-heading pb-2 mb-0']}>
    <slot />
  </Tag>
  <span class="section-heading__bar" aria-hidden="true"></span>
</div>

<style>
  .section-heading {
    position: relative;
    display: block;
    width: fit-content;
  }
  .section-heading__bar {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 4px;
    border-radius: 9999px;
    background-image: linear-gradient(
      to right,
      hsl(var(--primary)),
      hsl(var(--secondary)),
      hsl(var(--accent))
    );
    box-shadow: 0 0 12px hsl(var(--primary) / 0.5);
  }
</style>
