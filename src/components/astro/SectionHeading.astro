---
interface Props {
  as?: 'h1' | 'h2' | 'h3';
  id?: string;
  class?: string;
}

const { as: Tag = 'h2', id, class: className = '' } = Astro.props;
---

<Tag id={id} class:list={['section-title', className]}>
  <slot />
</Tag>

<style>
  .section-title {
    margin: 0 0 2rem;
    text-wrap: balance;
  }
</style>
