---
import testimonials from '@/data/testimonials.json';
import profile from '@/data/profile.json';
import ScrollReveal from './ScrollReveal.astro';
---

<section class="testimonials-section py-20 bg-card/30 border-y border-white/5" aria-labelledby="testimonials-heading">
  <div class="container mx-auto px-4">
    <ScrollReveal>
      <div class="text-center mb-16">
        <div class="relative inline-block mb-4">
          <h2 id="testimonials-heading" class="text-4xl font-bold text-white pb-2 mb-0">Peer Collaborations</h2>
          <span class="absolute bottom-0 left-0 w-full h-1 rounded-full bg-gradient-to-r from-primary-500 via-secondary-500 to-accent-500 shadow-[0_0_12px_rgba(14,165,233,0.5)]" aria-hidden="true"></span>
        </div>
        <p class="text-xl text-neutral-200 max-w-2xl mx-auto">
          What teammates say about working together on projects.
        </p>
      </div>
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((t, i) => (
        <ScrollReveal delay={i * 150}>
          <blockquote class="bg-card/60 backdrop-blur-sm border border-white/10 rounded-xl p-8 shadow-lg relative h-full">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary-500 to-secondary-500 mr-4 shrink-0" aria-hidden="true"></div>
              <div>
                <cite class="text-lg font-semibold text-foreground not-italic">{t.author}</cite>
                <p class="text-muted-foreground text-sm">{t.position}</p>
                <p class="text-muted-foreground text-xs">{t.organization}</p>
              </div>
            </div>
            <p class="text-medium-contrast italic mb-2">"{t.quote}"</p>
            <footer class="text-xs text-muted-foreground">Project: {t.project}</footer>
          </blockquote>
        </ScrollReveal>
      ))}
    </div>

    <div class="mt-16 flex flex-wrap justify-center gap-8">
      <div class="bg-white/10 rounded-lg px-6 py-4 text-center">
        <p class="text-3xl font-bold text-white">{profile.stats.teamProjects}</p>
        <p class="text-neutral-200">Team Projects</p>
      </div>
      <div class="bg-white/10 rounded-lg px-6 py-4 text-center">
        <p class="text-3xl font-bold text-white">{profile.stats.hackathons}</p>
        <p class="text-neutral-200">Hackathons</p>
      </div>
      <div class="bg-white/10 rounded-lg px-6 py-4 text-center">
        <p class="text-3xl font-bold text-white">{profile.stats.peerRating}</p>
        <p class="text-neutral-200">Peer Rating</p>
      </div>
    </div>
  </div>
</section>
