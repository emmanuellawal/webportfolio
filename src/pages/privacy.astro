---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy" description="Privacy policy for emmanuellawal.dev" path="/privacy">
  <div class="site-shell section-pad max-w-3xl prose-blog">
    <h1>Privacy Policy</h1>
    <p><strong>Last updated:</strong> June 2025</p>
    <p>
      This site collects no personal data beyond what you voluntarily submit through the contact form
      or standard server logs from your hosting provider. Contact form submissions are processed by
      a third-party form service and emailed directly to the site owner.
    </p>
    <h2>Analytics</h2>
    <p>
      This site may use privacy-focused analytics to understand traffic patterns. No personally
      identifiable information is sold or shared with advertisers.
    </p>
    <h2>Cookies</h2>
    <p>This static site does not set tracking cookies.</p>
    <h2>Contact</h2>
    <p>
      Questions about this policy? Email
      <a href="mailto:emmanuellawal2024@gmail.com">emmanuellawal2024@gmail.com</a>.
    </p>
  </div>
</BaseLayout>
