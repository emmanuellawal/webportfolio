---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ScrollReveal from '@/components/astro/ScrollReveal.astro';
import projects from '@/data/projects.json';
import { creativeWorkJsonLd, breadcrumbJsonLd } from '@/lib/jsonld';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout
  title={project.title}
  description={project.description}
  path={`/projects/${project.slug}`}
  ogImage={project.image}
  jsonLd={[
    creativeWorkJsonLd({
      title: project.title,
      description: project.longDescription,
      slug: project.slug,
      url: project.liveUrl,
      githubUrl: project.githubUrl,
      tags: project.tags,
    }),
    breadcrumbJsonLd([
      { name: 'Home', path: '/' },
      { name: 'Projects', path: '/projects' },
      { name: project.title, path: `/projects/${project.slug}` },
    ]),
  ]}
>
  <article class="case-study">
    <div class="site-shell section-pad">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/projects" class="text-link">Work</a>
        <span aria-hidden="true"> / </span>
        <span>{project.title}</span>
      </nav>

      <ScrollReveal>
        <header class="case-study__header">
          <h1>{project.title}</h1>
          <p class="case-study__lede">{project.description}</p>
        </header>
      </ScrollReveal>
    </div>

    <img
      src={project.image}
      alt={`Screenshot of ${project.title}`}
      width="1500"
      height="900"
      class="case-study__hero"
      loading="eager"
      decoding="async"
    />

    <div class="site-shell section-pad prose-editorial">
      <ScrollReveal>
        <section aria-labelledby="problem-heading">
          <h2 id="problem-heading">Problem</h2>
          <p>{project.longDescription}</p>
        </section>
      </ScrollReveal>

      <hr class="prose-editorial__rule" />

      <ScrollReveal>
        <section aria-labelledby="outcome-heading">
          <h2 id="outcome-heading">Outcome</h2>
          <p>{project.outcome}</p>
        </section>
      </ScrollReveal>

      <hr class="prose-editorial__rule" />

      <ScrollReveal>
        <section aria-labelledby="stack-heading">
          <h2 id="stack-heading">Stack</h2>
          <p class="text-muted">{project.tags.join(', ')}.</p>
        </section>
      </ScrollReveal>

      <div class="case-study__actions">
        {project.liveUrl && (
          <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
            View live demo
          </a>
        )}
        <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="btn-ghost">
          View code
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .breadcrumb {
    font-size: 0.875rem;
    color: var(--text-3);
    margin-bottom: 2rem;
  }

  .case-study__header {
    max-width: 42rem;
    margin-bottom: 2rem;
  }

  .case-study__lede {
    font-size: 1.125rem;
    color: var(--text-2);
    margin: 0;
    max-width: 38ch;
  }

  .case-study__hero {
    display: block;
    width: 100%;
    max-height: 32rem;
    object-fit: cover;
    object-position: top center;
    border-block: 1px solid var(--hairline);
  }

  .case-study__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.5rem;
  }

  .prose-editorial h2 {
    font-size: 1.375rem;
    margin: 0 0 0.75rem;
  }

  .prose-editorial p {
    color: var(--text-2);
    max-width: 52ch;
  }
</style>
