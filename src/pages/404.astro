---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you requested could not be found." path="/404" noindex={true}>
  <div class="site-shell section-pad text-center max-w-lg mx-auto">
    <h1 class="mb-4">404</h1>
    <p class="text-muted text-lg mb-8">This page doesn't exist or has moved.</p>
    <a href="/" class="btn-primary">Back home</a>
  </div>
</BaseLayout>
