---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ErrorPage from '@/components/astro/ErrorPage.astro';
---

<BaseLayout title="Page Not Found" description="The page you requested could not be found." path="/404" noindex={true}>
  <ErrorPage
    code="404"
    title="Page not found"
    body="That URL does not exist on this site. Check the address, or head back to selected work."
    primaryHref="/projects"
    primaryLabel="View selected work"
    secondaryHref="/"
    secondaryLabel="Back home"
  />
</BaseLayout>
