---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/astro/PostCard.astro';
import ScrollReveal from '@/components/astro/ScrollReveal.astro';
import SectionHeading from '@/components/astro/SectionHeading.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '@/lib/reading-time';
import { breadcrumbJsonLd } from '@/lib/jsonld';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Writing"
  description="Articles on web development, performance, accessibility, and AI by Emmanuel Lawal."
  path="/blog"
  jsonLd={breadcrumbJsonLd([{ name: 'Home', path: '/' }, { name: 'Blog', path: '/blog' }])}
>
  <div class="site-shell section-pad max-w-3xl">
    <ScrollReveal>
      <header class="mb-10">
        <SectionHeading as="h1">Writing</SectionHeading>
        <p class="text-muted">
          Notes on building fast, accessible web experiences — and using AI without losing taste.
        </p>
      </header>
    </ScrollReveal>

    <div>
      {
        posts.map((post, index) => (
          <ScrollReveal animation="ledger" delay={index * 40}>
            <PostCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              readingTime={getReadingTime(post.body ?? '')}
            />
          </ScrollReveal>
        ))
      }
    </div>

    {posts.length === 0 && (
      <p class="empty-state">No posts yet. Check back when the next note ships.</p>
    )}
  </div>
</BaseLayout>
