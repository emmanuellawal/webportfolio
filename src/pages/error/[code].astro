---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ErrorPage from '@/components/astro/ErrorPage.astro';

/**
 * Static stand-ins for host-level error pages.
 * Point Vercel/Netlify error routes here when configuring the deploy.
 */
export function getStaticPaths() {
  const errors = {
    '400': {
      title: 'Bad request',
      body: 'The request could not be understood. Try again from the homepage.',
    },
    '401': {
      title: 'Sign-in required',
      body: 'This area needs authentication. This portfolio has no private routes — return home.',
    },
    '403': {
      title: 'Access denied',
      body: 'You do not have permission to view this resource.',
    },
    '429': {
      title: 'Too many requests',
      body: 'Slow down for a moment, then try again. The contact form is the usual culprit.',
    },
    '500': {
      title: 'Something broke',
      body: 'A server error interrupted this page. Refresh, or email me if it keeps happening.',
    },
  } as const;

  return (Object.keys(errors) as Array<keyof typeof errors>).map((code) => ({
    params: { code },
    props: { code, title: errors[code].title, body: errors[code].body },
  }));
}

interface Props {
  code: string;
  title: string;
  body: string;
}

const { code, title, body } = Astro.props as Props;
---

<BaseLayout
  title={`${code} — ${title}`}
  description={body}
  path={`/error/${code}`}
  noindex={true}
>
  <ErrorPage
    code={code}
    title={title}
    body={body}
    primaryHref="/"
    primaryLabel="Back home"
    secondaryHref="/about#contact"
    secondaryLabel="Email me"
  />
</BaseLayout>
