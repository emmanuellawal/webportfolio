---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/astro/Hero.astro';
import ScrollReveal from '@/components/astro/ScrollReveal.astro';
import SectionHeading from '@/components/astro/SectionHeading.astro';
import ContactForm from '@/components/react/ContactForm';
import projects from '@/data/projects.json';
import experience from '@/data/experience.json';
import profile from '@/data/profile.json';
import { getCollection } from 'astro:content';
import { getReadingTime } from '@/lib/reading-time';

const featuredProjects = projects.filter((p) => p.featured).slice(0, 3);

const projectImages: Record<string, string> = {
  'three-decades-of-mobility':
    'https://picsum.photos/seed/mobility-dataviz-dashboard-dark-ui/1500/900',
  'ai-enhanced-calculator':
    'https://picsum.photos/seed/mobile-calculator-nlp-app-screen/800/1000',
  'cultural-ai':
    'https://picsum.photos/seed/cultural-ai-recommendation-app-ui/1500/900',
};

const signalTags = ['signal-tag--violet', 'signal-tag--orange', 'signal-tag--violet'];

const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const recentPosts = allPosts.slice(0, 3);
---

<BaseLayout path="/">
  <Hero />

  <section id="work" class="section-pad bg-site-2" aria-labelledby="work-heading">
    <div class="site-shell-wide">
      <div class="section-header-row">
        <SectionHeading id="work-heading">Selected work</SectionHeading>
        <a href="/projects" class="text-link">All projects</a>
      </div>

      <div class="ledger">
        {
          featuredProjects.map((project, index) => (
            <ScrollReveal animation="ledger" delay={index * 50}>
              <a href={`/projects/${project.slug}`} class="ledger__row">
                <img
                  src={projectImages[project.slug] ?? project.image}
                  alt={`Screenshot of ${project.title}`}
                  width="150"
                  height="94"
                  loading="lazy"
                  decoding="async"
                  class="ledger__thumb"
                />
                <div>
                  <h3 class="ledger__title">{project.title}</h3>
                  <p class="ledger__meta">
                    <span class:list={['signal-tag', signalTags[index]]}>
                      {project.tags[0]}
                    </span>
                    {' '}
                    {project.outcome}
                  </p>
                </div>
                <span class="ledger__arrow" aria-hidden="true">→</span>
              </a>
            </ScrollReveal>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-pad bg-invert" aria-labelledby="approach-heading">
    <div class="site-shell prose-editorial prose-editorial--invert">
      <SectionHeading id="approach-heading">How the work gets made</SectionHeading>
      <p>
        I start with constraints: who uses this, what has to be legible in five seconds, and what
        should still feel considered at pixel level. That order keeps AI, frameworks, and motion
        in their place — tools that sharpen the idea, not replace it.
      </p>
      <hr class="prose-editorial__rule" />
      <h3 class="approach-subhead">Where AI fits</h3>
      <p>
        AI shows up where it saves real time — parsing intent, surfacing patterns, accelerating
        iteration — never as decoration. The goal is work you would not expect to be AI-assisted
        because the details still read human.
      </p>
      <img
        src="https://picsum.photos/seed/developer-workspace-evening-monitor-only/1600/900"
        alt="Quiet workspace with a single monitor showing code and design side by side"
        width="1600"
        height="900"
        loading="lazy"
        decoding="async"
        class="approach-photo"
      />
    </div>
  </section>

  <section class="section-pad bg-site" aria-labelledby="experience-heading">
    <div class="site-shell">
      <SectionHeading id="experience-heading">Experience</SectionHeading>
      <div>
        {
          experience.map((item, index) => (
            <ScrollReveal animation="ledger" delay={index * 60}>
              <article class="experience-item">
                <div class="experience-item__header">
                  <h3 class="experience-item__role">{item.title}</h3>
                  <p class="experience-item__period">{item.period}</p>
                </div>
                <p class="experience-item__org">
                  {item.organization} · {item.location}
                </p>
                <p class="experience-item__summary">{item.summary}</p>
              </article>
            </ScrollReveal>
          ))
        }
      </div>
    </div>
  </section>

  {
    recentPosts.length > 0 && (
      <section class="section-pad bg-site-2" aria-labelledby="writing-heading">
        <div class="site-shell">
          <div class="section-header-row">
            <SectionHeading id="writing-heading">Writing</SectionHeading>
            <a href="/blog" class="text-link">All posts</a>
          </div>
          <div>
            {recentPosts.map((post, index) => (
              <ScrollReveal animation="ledger" delay={index * 50}>
                <a href={`/blog/${post.slug}`} class="writing-list__row">
                  <h3 class="writing-list__title">{post.data.title}</h3>
                  <p class="writing-list__meta">
                    {post.data.pubDate.toLocaleDateString('en-US', {
                      month: 'short',
                      day: 'numeric',
                      year: 'numeric',
                    })}
                    {' · '}
                    {getReadingTime(post.body ?? '')}
                  </p>
                </a>
              </ScrollReveal>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section id="contact" class="section-pad bg-site scroll-mt-24" aria-labelledby="contact-heading">
    <div class="site-shell contact-grid">
      <div>
        <SectionHeading id="contact-heading">Start a project</SectionHeading>
        <p class="text-muted">{profile.availability.details}</p>
        <p class="contact-resume">
          <a href="/resume.txt" download="Emmanuel-Lawal-Resume.txt" class="text-link">
            Download resume
          </a>
        </p>
      </div>
      <div class="contact-form-wrap">
        <ContactForm client:visible />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section-header-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .section-header-row .section-title {
    margin-bottom: 0;
  }

  .approach-subhead {
    font-size: 1.25rem;
    margin: 0 0 0.75rem;
  }

  .approach-photo {
    display: block;
    width: 100%;
    margin-top: 2rem;
    border-radius: var(--radius-xs);
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .contact-grid {
    display: grid;
    gap: 2.5rem;
    align-items: start;
  }

  .contact-resume {
    margin-top: 1.5rem;
  }

  .contact-form-wrap {
    max-width: 32rem;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }
</style>
