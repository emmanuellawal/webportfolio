---
import '@/styles/fonts.css';
import '@/styles/globals.css';
import SEOHead from '@/components/astro/SEOHead.astro';
import SkipLink from '@/components/astro/SkipLink.astro';
import Footer from '@/components/astro/Footer.astro';
import MainNav from '@/components/react/MainNav';
import JsonLd from '@/components/astro/JsonLd.astro';
import { personJsonLd, websiteJsonLd } from '@/lib/jsonld';
import type { SEOProps } from '@/lib/seo';

interface Props extends SEOProps {
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { jsonLd, ...seoProps } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead {...seoProps} />
    <link
      rel="preload"
      href="/fonts/archivo-latin-wght.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <JsonLd data={[personJsonLd(), websiteJsonLd(), ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])]} />
  </head>
  <body class="antialiased min-h-screen flex flex-col truncate-safe">
    <SkipLink />
    <div class="scroll-sentinel" aria-hidden="true"></div>
    <MainNav client:idle currentPath={currentPath} />
    <noscript>
      <nav class="noscript-nav" aria-label="Main navigation">
        <a href="/">Home</a>
        <a href="/projects">Work</a>
        <a href="/blog">Writing</a>
        <a href="/about">About</a>
        <a href="/resume.txt" download="Emmanuel-Lawal-Resume.txt">Resume</a>
      </nav>
    </noscript>
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (function () {
        function applyObfuscatedEmails() {
          var u = 'emmanuellawal2024';
          var d = 'gmail' + '.' + 'com';
          document.querySelectorAll('[data-obfuscated-email]').forEach(function (el) {
            el.setAttribute('href', 'mailto:' + u + '@' + d);
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', applyObfuscatedEmails);
        } else {
          applyObfuscatedEmails();
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  .scroll-sentinel {
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 1px;
    pointer-events: none;
  }

  .noscript-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    padding-block: 1rem;
    padding-inline: 1rem;
    border-bottom: 1px solid var(--hairline);
    background: var(--bg);
  }

  .noscript-nav a {
    color: var(--text-2);
    text-decoration: none;
    font-weight: 500;
    min-height: 2.75rem;
    display: inline-flex;
    align-items: center;
  }

  @media (scripting: none) {
    .site-header {
      background: var(--bg) !important;
      border-bottom-color: var(--hairline) !important;
    }
  }
</style>
