---
import '@fontsource-variable/archivo/wght.css';
import '@/styles/globals.css';
import archivoLatinUrl from '@fontsource-variable/archivo/files/archivo-latin-wght-normal.woff2?url';
import SEOHead from '@/components/astro/SEOHead.astro';
import SkipLink from '@/components/astro/SkipLink.astro';
import Footer from '@/components/astro/Footer.astro';
import MainNav from '@/components/react/MainNav';
import JsonLd from '@/components/astro/JsonLd.astro';
import { personJsonLd, websiteJsonLd } from '@/lib/jsonld';
import type { SEOProps } from '@/lib/seo';

interface Props extends SEOProps {
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { jsonLd, ...seoProps } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <link rel="preload" href={archivoLatinUrl} as="font" type="font/woff2" crossorigin />
    <SEOHead {...seoProps} />
    <JsonLd data={[personJsonLd(), websiteJsonLd(), ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])]} />
    <noscript>
      <style>
        .scroll-reveal {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>
  </head>
  <body class="antialiased min-h-screen flex flex-col">
    <SkipLink />
    <div class="scroll-sentinel" aria-hidden="true"></div>
    <MainNav client:idle currentPath={currentPath} />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (function () {
        function applyObfuscatedEmails() {
          var u = 'emmanuellawal2024';
          var d = 'gmail' + '.' + 'com';
          document.querySelectorAll('[data-obfuscated-email]').forEach(function (el) {
            el.setAttribute('href', 'mailto:' + u + '@' + d);
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', applyObfuscatedEmails);
        } else {
          applyObfuscatedEmails();
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  .scroll-sentinel {
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 1px;
    pointer-events: none;
  }
</style>
