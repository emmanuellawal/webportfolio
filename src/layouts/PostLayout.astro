---
import BaseLayout from './BaseLayout.astro';
import { formatDate, slugify } from '@/lib/utils';
import { getReadingTime } from '@/lib/reading-time';
import { blogPostingJsonLd, breadcrumbJsonLd } from '@/lib/jsonld';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'blog'>;
  prev?: CollectionEntry<'blog'>;
  next?: CollectionEntry<'blog'>;
}

const { entry, prev, next } = Astro.props;
const { title, description, pubDate, updatedDate, tags, heroImage, ogImage } = entry.data;
const postImage = ogImage ?? heroImage;
const { Content, headings } = await entry.render();
const readingTime = getReadingTime(entry.body ?? '');
const slug = entry.slug;

const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

<BaseLayout
  title={title}
  description={description}
  path={`/blog/${slug}`}
  type="article"
  publishedTime={pubDate.toISOString()}
  modifiedTime={(updatedDate ?? pubDate).toISOString()}
  tags={tags}
  ogImage={postImage}
  jsonLd={[
    blogPostingJsonLd({ title, description, slug, pubDate, updatedDate, tags, image: postImage }),
    breadcrumbJsonLd([
      { name: 'Home', path: '/' },
      { name: 'Blog', path: '/blog' },
      { name: title, path: `/blog/${slug}` },
    ]),
  ]}
>
  <article class="site-shell section-pad max-w-3xl">
    <header class="mb-10">
      <nav aria-label="Breadcrumb" class="breadcrumb text-subtle text-sm mb-4">
        <a href="/blog" class="text-link">Writing</a>
        <span aria-hidden="true"> / </span>
        <span>{title}</span>
      </nav>
      <h1 class="mb-4">{title}</h1>
      <p class="text-muted text-lg mb-4">{description}</p>
      <div class="flex flex-wrap items-center gap-3 text-sm text-subtle">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        <span aria-hidden="true">·</span>
        <span>{readingTime} min read</span>
        {
          updatedDate && (
            <>
              <span aria-hidden="true">·</span>
              <span>Updated {formatDate(updatedDate)}</span>
            </>
          )
        }
      </div>
      {
        tags.length > 0 && (
          <p class="text-subtle text-sm mt-4 mb-0">
            {tags.map((tag, i) => (
              <>
                {i > 0 && ', '}
                <a href={`/blog/tags/${slugify(tag)}`} class="text-link text-sm">{tag}</a>
              </>
            ))}
          </p>
        )
      }
    </header>

    {
      toc.length > 0 && (
        <nav aria-label="Table of contents" class="toc mb-10">
          <h2 class="toc__title">On this page</h2>
          <ol class="toc__list">
            {toc.map((h) => (
              <li style={`padding-left: ${(h.depth - 2) * 12}px`}>
                <a href={`#${h.slug}`} class="text-link text-sm">{h.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      )
    }

    <div class="prose-blog">
      <Content />
    </div>

    <nav class="post-nav" aria-label="Post navigation">
      {prev ? (
        <a href={`/blog/${prev.slug}`} class="text-link">
          ← {prev.data.title}
        </a>
      ) : (
        <span />
      )}
      {next ? (
        <a href={`/blog/${next.slug}`} class="text-link text-right">
          {next.data.title} →
        </a>
      ) : (
        <span />
      )}
    </nav>
  </article>
</BaseLayout>

<style>
  .toc {
    padding: 1rem 1.25rem;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-sm);
    background: var(--surface);
  }

  .toc__title {
    font-size: 0.875rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
  }

  .toc__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .post-nav {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--hairline);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .post-nav {
      flex-direction: row;
      justify-content: space-between;
    }
  }
</style>
