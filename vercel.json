{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/403",
      "dest": "/403/index.html",
      "status": 403
    },
    {
      "src": "/500",
      "dest": "/500.html",
      "status": 500
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/404.html",
      "status": 404
    }
  ]
}
